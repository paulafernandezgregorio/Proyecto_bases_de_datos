    DROP COLUMN IF EXISTS profile_path,
    DROP COLUMN IF EXISTS "order";


-- ============================================================
-- credits_crew: eliminar profile_path
-- profile_path: URL interna de imagen del crew, no usable
-- ============================================================
ALTER TABLE raw.credits_crew
    DROP COLUMN IF EXISTS profile_path;


